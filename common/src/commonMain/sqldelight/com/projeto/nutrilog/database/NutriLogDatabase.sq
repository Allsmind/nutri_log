searchFoods:
SELECT * FROM FoodEntity WHERE name LIKE ? ORDER BY name ASC;

insertFood:
INSERT OR REPLACE INTO FoodEntity(name, caloriesPer100g, proteinPer100g, carbPer100g, fatPer100g)
VALUES (?, ?, ?, ?, ?);
